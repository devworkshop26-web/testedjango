# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# URL where the frontend is hosted (Render service URL)
APP_URL="https://lucrabe-front.onrender.com"

# PostgreSQL backend configuration (fallback if DATABASE_URL is not set)
DB_ENGINE="django.db.backends.postgresql"
DB_NAME="lucrabe"
DB_USER="postgres"
DB_PASSWORD="postgres"
DB_HOST="localhost"
DB_PORT="5432"

# Preferred in production (Render PostgreSQL / external managed Postgres)
DATABASE_URL="postgresql://user:password@host:5432/database"
DB_SSLMODE="require"

# Security / domains
ALLOWED_HOSTS="localhost,127.0.0.1,lucrabe-front.onrender.com"
CORS_ALLOW_ORIGINS="http://localhost:5173,https://lucrabe-front.onrender.com"
CSRF_TRUSTED_ORIGINS="http://localhost:5173,https://lucrabe-front.onrender.com"

# Frontend env
VITE_API_BASE_URL="http://localhost:8000/api"
